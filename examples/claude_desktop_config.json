{
  "mcpServers": {
    "lyth-mcp": {
      "command": "node",
      "args": ["/absolute/path/to/lyth_mcp/dist/index.js"],
      "env": {
        "LYTH_NETWORK": "testnet-69420",
        "LYTH_CHAIN_ID": "69420",
        "LYTH_MCP_ENABLE_SUBMIT": "0",
        "LYTH_MCP_WALLET_STORE": "/absolute/path/to/.lyth_mcp/wallets.json",
        "LYTH_MCP_HOT_KEY": "/absolute/path/to/.lyth_mcp/hot.key",
        "LYTH_MCP_LOCAL_KEY": "/absolute/path/to/.lyth_mcp/local.key",
        "LYTH_MCP_ADDRESSBOOK": "/absolute/path/to/.lyth_mcp/addressbook.json",
        "LYTH_MCP_CONNECTOR_STORE": "/absolute/path/to/.lyth_mcp/connectors.json",
        "LYTH_MCP_CONNECTOR_KEY": "/absolute/path/to/.lyth_mcp/connector.key",
        "LYTH_MCP_ORDER_STORE": "/absolute/path/to/.lyth_mcp/orders.json",
        "LYTH_MCP_BOOKING_STORE": "/absolute/path/to/.lyth_mcp/bookings.json",
        "LYTH_MCP_INVOICE_STORE": "/absolute/path/to/.lyth_mcp/invoices.json",
        "LYTH_MCP_MERCHANT_POLICY_STORE": "/absolute/path/to/.lyth_mcp/merchant_policies.json",
        "LYTH_MCP_ASSET_REGISTRY": "/absolute/path/to/lyth_mcp/asset_registry.example.json",
        "LYTH_MCP_BRIDGE_ROUTE_REGISTRY": "/absolute/path/to/lyth_mcp/bridge_routes.example.json",
        "LYTH_MCP_VENDOR_REGISTRY": "/absolute/path/to/lyth_mcp/vendors.example.json"
      }
    }
  }
}
