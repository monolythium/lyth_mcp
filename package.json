{
  "name": "lyth-mcp",
  "version": "0.1.0",
  "description": "Monolythium MCP server for live-chain reads and AI runbooks.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "bin": {
    "lyth-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs",
    "examples",
    "fixtures",
    "runbooks",
    "scripts/verify-dist.cjs",
    "scripts/smoke.mjs",
    "asset_registry.example.json",
    "bridge_routes.example.json",
    "clusters.example.json",
    "nodes.example.json",
    "vendors.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node scripts/smoke.mjs",
    "prepare": "node scripts/verify-dist.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@monolythium/core-sdk": "https://github.com/monolythium-vision/mono-core-sdk/archive/ffeb897e4b710b4ee993a0c78bdde3f505009ae6.tar.gz",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
